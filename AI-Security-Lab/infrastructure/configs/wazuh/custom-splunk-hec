#!/usr/bin/env python3
import sys, json, ssl, urllib.request

alert_file, api_key, hook_url = sys.argv[1], sys.argv[2], sys.argv[3]

with open(alert_file) as f:
    alert = json.load(f)

# Only stdlib modules here (no `requests`) - the wazuh-manager image's bundled
# Python doesn't have third-party packages installed for integration scripts.
payload = json.dumps({"event": alert, "sourcetype": "_json"}).encode("utf-8")
req = urllib.request.Request(
    hook_url,
    data=payload,
    headers={"Authorization": f"Splunk {api_key}", "Content-Type": "application/json"},
    method="POST",
)

# Splunk HEC uses a self-signed cert by default; fine to skip verification on this internal-only lab VPC.
ctx = ssl.create_default_context()
ctx.check_hostname = False
ctx.verify_mode = ssl.CERT_NONE

try:
    urllib.request.urlopen(req, context=ctx, timeout=10)
except Exception:
    pass
